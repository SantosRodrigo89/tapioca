rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isTenantAdmin(tenantId) {
      return isSignedIn() && request.auth.token.tenantId == tenantId;
    }

    function isOwnerOrSuperAdmin(tenantId) {
      return isTenantAdmin(tenantId) || isSuperAdmin();
    }

    function tenantDoc(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId));
    }

    function isTenantActive(tenantId) {
      return tenantDoc(tenantId).data.status in ['trial', 'active'];
    }

    function canWriteTenantData(tenantId) {
      return isOwnerOrSuperAdmin(tenantId)
        && (isSuperAdmin() || isTenantActive(tenantId));
    }

    // ─── slugIndex ────────────────────────────────────────────────────────────
    // Lookups only via Admin SDK (SSR); client reads denied
    match /slugIndex/{slug} {
      allow read: if false;
      allow write: if isSuperAdmin();
    }

    // ─── tenants ─────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isOwnerOrSuperAdmin(tenantId);
      allow create: if false;
      allow update: if canWriteTenantData(tenantId)
        && request.resource.data.slug == resource.data.slug
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (isSuperAdmin() || (
          request.resource.data.planId == resource.data.planId
          && request.resource.data.templateId == resource.data.templateId
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.status == resource.data.status
        ));
      allow delete: if isSuperAdmin();

      match /categories/{categoryId} {
        allow read: if isOwnerOrSuperAdmin(tenantId);
        allow write: if canWriteTenantData(tenantId);

        match /items/{itemId} {
          allow read: if isOwnerOrSuperAdmin(tenantId);
          allow write: if canWriteTenantData(tenantId);
        }
      }

      match /gallery/{imageId} {
        allow read: if isOwnerOrSuperAdmin(tenantId);
        allow write: if canWriteTenantData(tenantId);
      }
    }

    // ─── Platform (SaaS foundation) — super_admin only ───────────────────────
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /plans/{planId} {
      allow read, write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read, write: if isSuperAdmin();
    }

    match /templates/{templateId} {
      allow read, write: if isSuperAdmin();
    }

    match /invites/{inviteId} {
      allow read, write: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
