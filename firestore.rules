rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isTenantAdmin(tenantId) {
      return isSignedIn() && request.auth.token.tenantId == tenantId;
    }

    function isOwnerOrSuperAdmin(tenantId) {
      return isTenantAdmin(tenantId) || isSuperAdmin();
    }

    function tenantDoc(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId));
    }

    function isTenantActive(tenantId) {
      let status = tenantDoc(tenantId).data.status;
      return status == 'trial' || status == 'active' || status == null;
    }

    function isTenantResourceActive() {
      let status = resource.data.status;
      return status == 'trial' || status == 'active' || status == null;
    }

    function canWriteTenantData(tenantId) {
      return isOwnerOrSuperAdmin(tenantId)
        && (isSuperAdmin() || isTenantActive(tenantId));
    }

    function canUpdateTenantDoc(tenantId) {
      return isOwnerOrSuperAdmin(tenantId)
        && (isSuperAdmin() || isTenantResourceActive());
    }

    // ─── slugIndex ────────────────────────────────────────────────────────────
    // Lookups only via Admin SDK (SSR); client reads denied
    match /slugIndex/{slug} {
      allow read: if false;
      allow write: if isSuperAdmin();
    }

    // ─── tenants ─────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isOwnerOrSuperAdmin(tenantId);
      allow create: if false;
      allow update: if canUpdateTenantDoc(tenantId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'description',
          'address',
          'whatsapp',
          'logoUrl',
          'bannerUrl',
          'theme',
          'openingHours',
          'highlightItemIds',
          'siteConfig',
          'updatedAt',
          'lastAccessAt',
        ]);
      allow delete: if isSuperAdmin();

      match /categories/{categoryId} {
        allow read: if isOwnerOrSuperAdmin(tenantId);
        allow write: if canWriteTenantData(tenantId);

        match /items/{itemId} {
          allow read: if isOwnerOrSuperAdmin(tenantId);
          allow write: if canWriteTenantData(tenantId);
        }
      }

      match /gallery/{imageId} {
        allow read: if isOwnerOrSuperAdmin(tenantId);
        allow write: if canWriteTenantData(tenantId);
      }
    }

    // ─── Platform (SaaS foundation) — super_admin only ───────────────────────
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /plans/{planId} {
      allow read, write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read, write: if isSuperAdmin();
    }

    match /templates/{templateId} {
      allow read, write: if isSuperAdmin();
    }

    match /invites/{inviteId} {
      allow read, write: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
