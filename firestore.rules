rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isTenantAdmin(tenantId) {
      return isSignedIn() && request.auth.token.tenantId == tenantId;
    }

    function isOwnerOrSuperAdmin(tenantId) {
      return isTenantAdmin(tenantId) || isSuperAdmin();
    }

    // ─── slugIndex ────────────────────────────────────────────────────────────
    // Public read for slug lookups; only super_admin or server-side writes
    match /slugIndex/{slug} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── tenants ─────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerUid;
      // slug, ownerUid and SaaS fields are immutable for tenant admins
      allow update: if isOwnerOrSuperAdmin(tenantId)
        && request.resource.data.slug == resource.data.slug
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (isSuperAdmin() || (
          request.resource.data.planId == resource.data.planId
          && request.resource.data.templateId == resource.data.templateId
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.status == resource.data.status
        ));
      allow delete: if isSuperAdmin();

      // ─── categories ────────────────────────────────────────────────────────
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isOwnerOrSuperAdmin(tenantId);

        // ─── items ───────────────────────────────────────────────────────────
        match /items/{itemId} {
          allow read: if true;
          allow write: if isOwnerOrSuperAdmin(tenantId);
        }
      }

      // ─── gallery ───────────────────────────────────────────────────────────
      match /gallery/{imageId} {
        allow read: if true;
        allow write: if isOwnerOrSuperAdmin(tenantId);
      }
    }

    // ─── Platform (SaaS foundation) — super_admin only ───────────────────────
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /plans/{planId} {
      allow read, write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read, write: if isSuperAdmin();
    }

    match /templates/{templateId} {
      allow read, write: if isSuperAdmin();
    }

    match /invites/{inviteId} {
      allow read, write: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
